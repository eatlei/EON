        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "환율은 매일 자동으로 갱신되며 구독 가격이 변동될 수 있습니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los tipos se actualizan a diario; los precios pueden cambiar."
