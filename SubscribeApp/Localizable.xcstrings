        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les taux sont actualisés quotidiennement ; les prix peuvent varier."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kurse werden täglich aktualisiert; Abopreise können sich ändern."
