    "瑰夏手冲级别的款待,开发者能记一整年": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Geisha-Pour-over-Geste – der Entwickler erinnert sich das ganze Jahr"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A Geisha pour-over level treat — the developer will remember it all year"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un detalle nivel Geisha en pour-over: el desarrollador lo recordará todo el año"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un cadeau digne d'un pour-over Geisha — le développeur s'en souviendra toute l'année"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ゲイシャ手淹れ級のおもてなし、開発者は一年覚えてます"
          }
        },
        "ko": {
