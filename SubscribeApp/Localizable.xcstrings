        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los tipos se actualizan a diario; los precios pueden cambiar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les taux sont actualisés quotidiennement ; les prix peuvent varier."
