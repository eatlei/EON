    "你养的不是订阅,是开发者": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du finanzierst kein Abo — du finanzierst einen Indie-Entwickler"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’re not just paying for an app — you’re feeding an indie dev"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No mantienes una app, mantienes a un dev independiente"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu ne finances pas une app, tu nourris un développeur indé"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたが支えてるのはアプリじゃなくて、開発者本人です"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구독이 아니라 개발자를 후원하고 있는 거예요"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你養的不是訂閱,是開發者"
          }
        }
      }
    },
    "你把人生跑成了一个 Excel 📊": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du führst dein Leben wie ein Excel 📊"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You run your life like a spreadsheet 📊"
