    "课买得比上得快,但也在前进 📚": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kurse schneller gekauft als belegt — aber du machst Fortschritte 📚"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Buying courses faster than finishing them — still moving forward 📚"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Compras cursos más rápido de lo que los terminas — y aun así avanzas 📚"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
