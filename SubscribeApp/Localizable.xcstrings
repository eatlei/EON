    "使用 iCloud Key-Value Store 同步当前订阅。真机需 Apple ID 与应用 iCloud 权限可用。" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Synchronisiert deine Abos über iCloud Key-Value Store. Auf echten Geräten sind Apple-ID und iCloud-Berechtigung erforderlich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Syncs subscriptions via iCloud Key-Value Store. Requires Apple ID and iCloud entitlement on device."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sincroniza las suscripciones mediante iCloud Key-Value Store. En dispositivo real necesita un Apple ID y permiso de iCloud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Synchronise les abonnements via iCloud Key-Value Store. Nécessite un identifiant Apple et l’autorisation iCloud sur appareil réel."
