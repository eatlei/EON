    "(不打赏也可以继续白嫖,我们做朋友 🤝)": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "(Auch ohne Trinkgeld bleiben wir Freunde 🤝)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "(No tip needed — we’re still friends 🤝)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "(Sin propina también seguimos siendo amigos 🤝)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "(Sans pourboire on reste amis 🤝)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "(投げ銭なしでも普通に友達です 🤝)"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "(후원 없어도 우리는 친구 🤝)"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "(不打賞也可以繼續白嫖,我們做朋友 🤝)"
          }
        }
      }
    },
