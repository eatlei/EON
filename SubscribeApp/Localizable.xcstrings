        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez votre premier abonnement et l’aperçu des dépenses apparaîtra ici."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge dein erstes Abo hinzu, dann erscheint hier deine Ausgabenübersicht."
          }
        }
      }
    },
    "添加后可在新增/编辑订阅时选择。": {
