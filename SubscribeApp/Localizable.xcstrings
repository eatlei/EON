    "爱奇艺、腾讯视频、网易云音乐、漫画 App —— 你的休闲时间被精挑细选的内容填得满满当当。沙发就是你的剧院。": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Netflix, Spotify, YouTube Premium, Comic-Apps — deine Freizeit ist kuratiert und voll."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Netflix, Spotify, YouTube Premium, comic apps — your downtime is curated and packed. The couch is your private theater."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Netflix, Spotify, YouTube Premium, apps de cómics — tu tiempo libre está curado al detalle."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Netflix, Spotify, YouTube Premium, apps de BD — tes temps libres sont triés sur le volet."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Netflix、Spotify、YouTube Premium、マンガアプリ。あなたの余暇は厳選コンテンツで満たされ、ソファは個人シアターに。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Netflix, Spotify, YouTube Premium, 만화 앱 — 당신의 여가는 엄선된 콘텐츠로 가득."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Netflix、Spotify、YouTube Premium、漫畫 App —— 你的休閒時間被精挑細選的內容填得滿滿當當。沙發就是你的劇院。"
          }
        }
      }
    },
